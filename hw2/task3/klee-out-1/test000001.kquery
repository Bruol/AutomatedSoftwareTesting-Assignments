array a[40] : w32 -> w8 = symbolic
(query [(Sle (ReadLSB w32 0 a)
              N0:(ReadLSB w32 4 a))
         (Sle N0
              N1:(ReadLSB w32 8 a))
         (Sle N1
              N2:(ReadLSB w32 12 a))
         (Sle N2
              N3:(ReadLSB w32 16 a))
         (Sle N3
              N4:(ReadLSB w32 20 a))
         (Sle N4
              N5:(ReadLSB w32 24 a))
         (Sle N5
              N6:(ReadLSB w32 28 a))
         (Sle N6
              N7:(ReadLSB w32 32 a))
         (Sle N7
              (ReadLSB w32 36 a))]
        false)
